# Render Environment Variables
# Copy this to .env and fill in your actual values

# MongoDB Connection String (use your MongoDB Atlas URI)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vidly?retryWrites=true&w=majority

# JWT Secret Key (generate a strong random string)
vidly_jwtPrivateKey=your-super-secret-jwt-key-min-256-chars

# Optional: Port (Render will set this automatically, but you can override)
PORT=3000

# Optional: Environment
NODE_ENV=production
